# Jussimatic API Configuration
# Copy this file to .env.local and fill in the actual values

# Base URL for the Jussimatic Node.js API backend
VITE_JUSSIMATIC_BACKEND_API_BASE_URL=https://your-api-url-here

# Base URL for the Laravel auth backend
VITE_JUSSILOG_BACKEND_API_BASE_URL=http://localhost:8000/api/

# Base URL for the Laravel storage (for images, etc.)
VITE_JUSSILOG_BACKEND_STORAGE_BASE_URL=http://localhost:8000/storage/

# Main title used in ecommerce navigation headers
VITE_ECOMMERCE_MAIN_TITLE=Ecommerce Demo

# Google Client ID for OAuth authentication
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Base URL for the AI CV review backend (Python service)
VITE_JUSSI_AIBOT_API_URL=https://your-aibot-api-url-here

# API key for the AI CV review backend
VITE_JUSSI_AIBOT_AI_SECRET_KEY=your-api-key-here

# App title shown in browser tab and search results (optional, has default)
VITE_APP_TITLE=Jussimatic - Portfolio by Jussi Alanen

# App description shown in search results and social sharing (optional, has default)
VITE_APP_DESCRIPTION=Jussimatic is the main portfolio by Jussi Alanen, including project references and live demos such as CV Review tool, CV Chat, Browse Jobs and Ecommerce.

# CV view — public resume endpoint credentials
# Used to fetch the primary resume: GET /api/resumes/current?owner=...&password=...
VITE_CV_ENDPOINT=http://example.com/api/resumes/current?owner=xxxxxxx&code=xxxx

# Base URL for the Laravel backend documentation (for "Docs" link in UI)
VITE_JUSSILOG_BACKEND_DOCS_URL=http://localhost:8000/